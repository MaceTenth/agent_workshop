# Copy this file to .env and fill in your values.
# The .env file is gitignored and will never be committed.

# You only need to set the key(s) for the provider(s) you plan to use.
# The app will show a warning banner for any provider whose key is missing
# and only lists that provider's models once a key is configured.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=sk-...
